generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. NÚCLEO MULTI-TENANT Y SEGURIDAD
// ==========================================

model Sucursal {
  id          String       @id @default(uuid())
  nombre      String
  direccion   String?
  activa      Boolean      @default(true)
  creadoEn    DateTime     @default(now())
  actualizado DateTime     @updatedAt

  usuarios    Usuario[]
  mesas       Mesa[]
  pedidos     Pedido[]
  cajas       CajaDiaria[]
  productos   Producto[]
  categorias  Categoria[]
  gastos      Gasto[]
}

model Usuario {
  id          String       @id @default(uuid())
  sucursalId  String
  sucursal    Sucursal     @relation(fields: [sucursalId], references: [id])
  
  nombre      String
  email       String       @unique
  telefono    String?      // Campo de contacto mantenido según requerimiento
  password    String       
  pinAcceso   String       @db.VarChar(4) // Autenticación rápida en terminal POS
  
  rol         Rol          @default(MOZO)
  activo      Boolean      @default(true)
  
  creadoEn    DateTime     @default(now())
  actualizado DateTime     @updatedAt
  eliminadoEn DateTime?    // Soft delete

  pedidos     Pedido[]
  cajas       CajaDiaria[]
  gastos      Gasto[]
}

enum Rol {
  ADMIN
  MOZO
  COCINA
  CAJA
}

// ==========================================
// 2. DOMINIO DE CLIENTES Y CONVENIOS
// ==========================================

model Empresa {
  id             String               @id @default(uuid())
  razonSocial    String
  ruc            String               @unique
  direccion      String?
  telefono       String?
  
  tieneCredito   Boolean              @default(false)
  limiteCredito  Decimal              @default(0) @db.Decimal(10, 2)
  creditoUsado   Decimal              @default(0) @db.Decimal(10, 2)
  diaCierre      Int                  @default(30)
  
  creadoEn       DateTime             @default(now())
  actualizado    DateTime             @updatedAt
  eliminadoEn    DateTime?

  convenios      ConvenioTrabajador[]
}

model Cliente {
  id             String               @id @default(uuid())
  nombre         String
  dni            String?              @unique
  ruc            String?              
  email          String?
  telefono       String?
  direccion      String?
  
  tieneCredito   Boolean              @default(false)
  limiteCredito  Decimal              @default(0) @db.Decimal(10, 2)
  saldoDeuda     Decimal              @default(0) @db.Decimal(10, 2)
  
  creadoEn       DateTime             @default(now())
  actualizado    DateTime             @updatedAt
  eliminadoEn    DateTime?

  pedidos        Pedido[]
  convenios      ConvenioTrabajador[] 
}

model ConvenioTrabajador {
  id             String    @id @default(uuid())
  clienteId      String
  empresaId      String
  limiteDiario   Decimal   @db.Decimal(10, 2)
  activo         Boolean   @default(true)

  creadoEn       DateTime  @default(now())
  actualizado    DateTime  @updatedAt

  cliente        Cliente   @relation(fields: [clienteId], references: [id])
  empresa        Empresa   @relation(fields: [empresaId], references: [id])
  pedidos        Pedido[]  // Pedidos asociados a este convenio específico

  @@unique([clienteId, empresaId])
}

// ==========================================
// 3. CATÁLOGO, MENÚ E INVENTARIO
// ==========================================

model Categoria {
  id          String      @id @default(uuid())
  sucursalId  String
  sucursal    Sucursal    @relation(fields: [sucursalId], references: [id])
  nombre      String
  orden       Int         @default(0)
  
  padreId     String?
  padre       Categoria?  @relation("Jerarquia", fields: [padreId], references: [id])
  hijos       Categoria[] @relation("Jerarquia")
  
  creadoEn    DateTime    @default(now())
  actualizado DateTime    @updatedAt
  eliminadoEn DateTime?

  productos   Producto[]
}

enum TipoArticulo {
  PLATO
  PRODUCTO
}

enum AreaDespacho {
  COCINA
  BARRA
}

model Producto {
  id              String                 @id @default(uuid())
  sucursalId      String
  sucursal        Sucursal               @relation(fields: [sucursalId], references: [id])
  nombre          String
  tipo            TipoArticulo           @default(PLATO) 
  precio          Decimal                @db.Decimal(10, 2)
  
  areaDespacho    AreaDespacho           @default(COCINA) // Enrutamiento para el KDS
  
  controlarStock  Boolean                @default(false)
  costo           Decimal                @default(0) @db.Decimal(10, 2)
  stock           Int                    @default(0)
  stockMinimo     Int                    @default(0)      // Para alertas visuales
  disponibleHoy   Boolean                @default(true)

  imagenUrl       String?
  
  categoriaId     String
  categoria       Categoria              @relation(fields: [categoriaId], references: [id])
  
  creadoEn        DateTime               @default(now())
  actualizado     DateTime               @updatedAt
  eliminadoEn     DateTime?

  detallesPedido  DetallePedido[]
  movimientos     MovimientoInventario[]
  menusSegundo    MenuDia[]              @relation("MenuSegundo")
  menusEntrada    MenuEntrada[]
}

model MenuDia {
  id             String          @id @default(uuid())
  nombre         String          
  precio         Decimal         @db.Decimal(10, 2)
  
  segundoId      String
  segundo        Producto        @relation("MenuSegundo", fields: [segundoId], references: [id])
  
  activo         Boolean         @default(true)
  creadoEn       DateTime        @default(now())
  actualizado    DateTime        @updatedAt

  entradas       MenuEntrada[]
  detallesPedido DetallePedido[]
}

model MenuEntrada {
  id          String   @id @default(uuid())
  menuId      String
  productoId  String   
  
  menu        MenuDia  @relation(fields: [menuId], references: [id], onDelete: Cascade)
  producto    Producto @relation(fields: [productoId], references: [id])
}

// ==========================================
// 4. OPERACIÓN EN SALÓN Y PEDIDOS
// ==========================================

model Mesa {
  id          String       @id @default(uuid())
  sucursalId  String
  sucursal    Sucursal     @relation(fields: [sucursalId], references: [id])
  numero      String       @db.VarChar(10)
  capacidad   Int
  ocupada     Boolean      @default(false)
  salon       String       @default("Principal")
  
  creadoEn    DateTime     @default(now())
  actualizado DateTime     @updatedAt

  pedidos     PedidoMesa[]

  @@unique([sucursalId, numero]) // El número de mesa es único por sucursal
}

model Pedido {
  id              String         @id @default(uuid())
  sucursalId      String
  sucursal        Sucursal       @relation(fields: [sucursalId], references: [id])
  
  usuarioId       String
  usuario         Usuario        @relation(fields: [usuarioId], references: [id])
  
  clienteId       String?        // Para cuentas corrientes personales
  cliente         Cliente?       @relation(fields: [clienteId], references: [id])

  convenioId      String?        // Reemplaza a empresaId para respetar el límite diario
  convenio        ConvenioTrabajador? @relation(fields: [convenioId], references: [id])

  tipo            TipoPedido     @default(MESA)
  direccion       String?
  
  estado          EstadoPedido   @default(PENDIENTE)
  motivoAnulacion String?        // Auditoría de cancelaciones
  
  total           Decimal        @db.Decimal(10, 2)
  fecha           DateTime       @default(now())
  creadoEn        DateTime       @default(now())
  actualizado     DateTime       @updatedAt
  
  estadoPago      EstadoPago     @default(POR_COBRAR)

  mesas           PedidoMesa[]   // Relación N:M para permitir fusión de mesas
  detalles        DetallePedido[]
  pagos           Pago[]

  @@index([sucursalId, fecha])
}

model PedidoMesa {
  pedidoId String
  mesaId   String
  
  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  mesa     Mesa   @relation(fields: [mesaId], references: [id], onDelete: Cascade)

  @@id([pedidoId, mesaId])
}

enum TipoPedido {
  MESA
  LLEVAR
  DELIVERY
}

enum EstadoPedido {
  PENDIENTE
  EN_PROCESO
  LISTO
  SERVIDO
  CERRADO
  CANCELADO
}

enum EstadoPago {
  POR_COBRAR
  PAGADO_PARCIAL
  PAGADO
}

model DetallePedido {
  id             String          @id @default(uuid())
  pedidoId       String
  productoId     String?
  cantidad       Int
  precioUnitario Decimal         @db.Decimal(10, 2)
  notas          String?         // Instrucciones para cocina (ej. "Sin cebolla")
  
  detallePadreId String?           
  detallePadre   DetallePedido?  @relation("PadreHijo", fields: [detallePadreId], references: [id])
  hijos          DetallePedido[] @relation("PadreHijo")

  menuId         String?
  menu           MenuDia?        @relation(fields: [menuId], references: [id])

  pedido         Pedido          @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto       Producto?       @relation(fields: [productoId], references: [id])
  
  creadoEn       DateTime        @default(now())
  actualizado    DateTime        @updatedAt
}

// ==========================================
// 5. CAJA, PAGOS Y FINANZAS
// ==========================================

model CajaDiaria {
  id            String    @id @default(uuid())
  sucursalId    String
  sucursal      Sucursal  @relation(fields: [sucursalId], references: [id])
  
  usuarioId     String       
  fechaApertura DateTime  @default(now())
  fechaCierre   DateTime?
  montoInicial  Decimal   @db.Decimal(10, 2)
  montoFinal    Decimal?  @db.Decimal(10, 2)
  observaciones String?   // Descuadres (Cierre ciego)
  estado        Boolean   @default(true)
  
  creadoEn      DateTime  @default(now())
  actualizado   DateTime  @updatedAt

  usuario       Usuario   @relation(fields: [usuarioId], references: [id])
  
  pagos         Pago[]
  gastos        Gasto[]
}

model CategoriaGasto {
  id          String    @id @default(uuid())
  sucursalId  String?   // Opcional si las categorías son globales para la empresa
  nombre      String    @unique
  esCosto     Boolean   @default(false)
  
  gastos      Gasto[]
}

model Gasto {
  id              String         @id @default(uuid())
  sucursalId      String
  sucursal        Sucursal       @relation(fields: [sucursalId], references: [id])
  
  descripcion     String
  monto           Decimal        @db.Decimal(10, 2)
  fecha           DateTime       @default(now())
  
  categoriaId     String
  categoria       CategoriaGasto @relation(fields: [categoriaId], references: [id])
  
  usuarioId       String?
  usuario         Usuario?       @relation(fields: [usuarioId], references: [id])
  
  cajaId          String?
  caja            CajaDiaria?    @relation(fields: [cajaId], references: [id])
  
  creadoEn        DateTime       @default(now())
  actualizado     DateTime       @updatedAt

  @@index([sucursalId, fecha])
}

model Pago {
  id              String     @id @default(uuid())
  pedidoId        String
  cajaId          String?    // ← agregado el ?
  monto           Decimal    @db.Decimal(10, 2)
  metodo          MetodoPago
  fecha           DateTime   @default(now())

  comprobanteUrl  String?
  tipoComprobante String?
  serie           String?
  numero          String?
  sunatEstado     String?
  codigoOperacion String?
  
  creadoEn        DateTime   @default(now())
  actualizado     DateTime   @updatedAt

  pedido          Pedido     @relation(fields: [pedidoId], references: [id])
  caja            CajaDiaria? @relation(fields: [cajaId], references: [id]) // ← también el ?
}

enum MetodoPago {
  EFECTIVO
  YAPE_PLIN
  TARJETA
  CREDITO_EMPRESA
  CREDITO_PERSONAL
}

// ==========================================
// 6. CONTROL DE INVENTARIO
// ==========================================

model MovimientoInventario {
  id            String         @id @default(uuid())
  productoId    String
  tipo          TipoMovimiento
  cantidad      Int
  fecha         DateTime       @default(now())
  motivo        String?
  costoUnitario Decimal?       @db.Decimal(10, 2)
  
  creadoEn      DateTime       @default(now())
  actualizado   DateTime       @updatedAt

  producto      Producto       @relation(fields: [productoId], references: [id], onDelete: Cascade)
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  AJUSTE
}